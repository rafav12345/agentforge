# Normalize line endings: store as LF in the repo, check out native.
* text=auto eol=lf

# Explicitly treat known text types as text
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary types (never normalize)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
